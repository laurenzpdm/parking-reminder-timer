{
  "expo": {
    "name": "Parking Reminder Timer",
    "slug": "parking-reminder-timer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thuemmlerai.parkingremindertimer",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Parking Reminder Timer can save your current spot so you can find your parked car again.",
        "NSUserNotificationsUsageDescription": "Parking Reminder Timer sends alerts before your meter expires."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "revenueCatEntitlement": "pro",
      "weeklyProductId": "parking_reminder_timer_weekly",
      "annualProductId": "parking_reminder_timer_annual"
    }
  }
}
